<Window x:Class="Lab_13.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Lab_13.ViewModels"
        Title="Телефонная книга — Lab_13"
        Height="550"
        Width="850"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Телефонная книга"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Height="32"
                     Margin="0,0,10,0"
                     VerticalContentAlignment="Center"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Поиск по имени или телефону"/>

            <Button Grid.Column="1"
                    Content="Обновить"
                    Width="90"
                    Margin="0,0,5,0"
                    Command="{Binding RefreshCommand}"/>

            <Button Grid.Column="2"
                    Content="Добавить"
                    Width="90"
                    Margin="0,0,5,0"
                    Command="{Binding AddCommand}"/>

            <Button Grid.Column="3"
                    Content="Изменить"
                    Width="90"
                    Margin="0,0,5,0"
                    Command="{Binding EditCommand}"/>

            <Button Grid.Column="4"
                    Content="Удалить"
                    Width="90"
                    Command="{Binding DeleteCommand}"/>
        </Grid>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Contacts}"
                  SelectedItem="{Binding SelectedContact}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  SelectionMode="Single">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="80"/>

                <DataGridTextColumn Header="Имя"
                                    Binding="{Binding Name}"
                                    Width="*"/>

                <DataGridTextColumn Header="Телефон"
                                    Binding="{Binding Phone}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3"
                Margin="0,15,0,0"
                Padding="15"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="5"
                Visibility="{Binding Editor.IsVisible, Converter={StaticResource BoolToVisibilityConverter}}">

            <StackPanel DataContext="{Binding Editor}">
                <TextBlock Text="{Binding Title}"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Имя:"/>
                <TextBox Text="{Binding NameInput, UpdateSourceTrigger=PropertyChanged}"
                         Height="30"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Телефон:"/>
                <TextBox Text="{Binding PhoneInput, UpdateSourceTrigger=PropertyChanged}"
                         Height="30"
                         Margin="0,0,0,15"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить"
                            Width="100"
                            Margin="0,0,10,0"
                            Command="{Binding SaveCommand}"/>

                    <Button Content="Отмена"
                            Width="100"
                            Command="{Binding CancelCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>